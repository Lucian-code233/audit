# Auth for the cursor `agent` CLI.
#
# Option (a): run `agent login` once — no .env needed.
# Option (b): set an API key here for CI / non-interactive use.
CURSOR_API_KEY=
# CURSOR_AUTH_TOKEN=     # alternative to CURSOR_API_KEY

# Per-stage models are configured in config/stages.yaml as cursor model
# names (e.g. composer-2.5, sonnet-4-thinking). Run `agent --list-models`
# to see what your account can use.
